{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Incident",
  "type": "object",
  "properties": {
    "incident_id": {
      "type": "string"
    },
    "service_type": {
      "type": "string"
    },
    "service_type_confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "original_category": {
      "type": "string"
    },
    "description_redacted": {
      "type": "string"
    },
    "neighborhood": {
      "type": "string"
    },
    "lat": {
      "type": "number"
    },
    "lon": {
      "type": "number"
    },
    "opened_at": {
      "type": "string",
      "format": "date-time"
    },
    "closed_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "status": {
      "type": "string"
    },
    "is_duplicate": {
      "type": "boolean"
    },
    "dedup_cluster_id": {
      "type": "string"
    },
    "agency": {
      "type": "string"
    },
    "source": {
      "type": "string"
    }
  },
  "required": [
    "incident_id",
    "service_type",
    "original_category",
    "opened_at"
  ]
}