# ============================================
# AgentCivic — Environment Configuration
# ============================================
# Copy this file to .env and fill in your keys:
#   cp example.env .env
# ============================================

# --- ASI:One LLM API ---
# Get your key at: https://asi1.ai
ASI1_API_KEY=your_asi1_api_key_here

# --- Fetch.ai Agentverse ---
# Agent seed phrases (generate unique ones for each agent)
# These give your agents persistent identities on Agentverse
ORCHESTRATOR_SEED="your_orchestrator_seed_phrase_here"
PROPOSER_SEED="your_proposer_seed_phrase_here"
VERIFIER_SEED="your_verifier_seed_phrase_here"
REDTEAM_SEED="your_redteam_seed_phrase_here"

# Agentverse mailbox API key (from agentverse.ai → Settings)
AGENTVERSE_API_KEY=your_agentverse_api_key_here

# --- LA Open Data (MyLA311) ---
# Optional: SODA API app token for higher rate limits
# Get one at: https://data.lacity.org/profile/edit/developer_settings
LA_DATA_APP_TOKEN=

# --- Backend Configuration ---
# FastAPI backend URL (agents connect to this)
AGENTCIVIC_BACKEND=http://localhost:8001

# --- Discord Bot (Optional) ---
DISCORD_TOKEN=
