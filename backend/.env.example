# ============================================================
# AgentCivic Backend — Environment Variables
# ============================================================
# Copy to .env:  cp .env.example .env
# ============================================================

# --- ASI:One LLM ---
ASI1_API_KEY=your_asi1_api_key_here

# --- Fetch.ai Agents ---
AGENTVERSE_TOKEN=your_agentverse_token_here
AGENTCIVIC_ORCHESTRATOR_SEED=agentcivic-orchestrator-unique-seed-2026
AGENTCIVIC_PROPOSER_SEED=agentcivic-proposer-unique-seed-2026
AGENTCIVIC_VERIFIER_SEED=agentcivic-verifier-unique-seed-2026
AGENTCIVIC_REDTEAM_SEED=agentcivic-redteam-unique-seed-2026
ORCHESTRATOR_PORT=8010
PROPOSER_PORT=8011
VERIFIER_PORT=8012
REDTEAM_PORT=8013

# --- LA 311 Open Data ---
LA_311_APP_TOKEN=your_socrata_app_token_here
LA_311_DATASET_ID=rq3b-xjk8
LA_311_BASE_URL=https://data.lacity.org/resource
LA_311_FETCH_LIMIT=50000
LA_311_LOOKBACK_DAYS=180

# --- FastAPI Server ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001
STREAM_PORT=8004
CORS_ORIGIN=http://localhost:3000
ENVIRONMENT=development

